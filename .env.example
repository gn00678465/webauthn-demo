DATABASE_URL=mongodb://USERNAME:PASSWORD@HOST:PORT/DATABASE
PORT=80
RP_ID=webauthn.localhost
RP_NAME=webauthn.localhost
SESSION_SECRET=

# WebAuthn origin allow-list (comma-separated)
# 驗證 clientDataJSON.origin 的期望值，未設定時使用程式內建預設值（正式環境 + Android debug 簽章）
# Android 格式：android:apk-key-hash:<base64url(SHA-256(簽章憑證))>
ALLOWED_ORIGINS=https://webauthn.localhost:5173

# .well-known configuration (all optional, unset = 404)
# ANDROID_PACKAGE_NAME=com.example.webauthn
# ANDROID_SHA256_FINGERPRINTS=XX:XX:XX:...:XX
# APPLE_APP_IDS=ABCDE12345.com.example.webauthn
# RELATED_ORIGINS=https://example.com,https://example.co.uk
# PASSKEY_ENROLL_URL=https://webauthn.localhost/passkeys/create
# PASSKEY_MANAGE_URL=https://webauthn.localhost/passkeys
