# WebAuthn origin allow-list (comma-separated)
# 驗證 clientDataJSON.origin 的期望值，未設定時使用程式內建預設值（正式環境 + Android debug 簽章）
# Android 格式：android:apk-key-hash:<base64url(SHA-256(簽章憑證))>
ALLOWED_ORIGINS=https://webauthn-demo-10ja.onrender.com,android:apk-key-hash:jjh-F27qoyZV7OtsfhPMMEdSUWOVEOlMHFixAUqmWSg

# .well-known configuration (all optional, unset = 404)
# Android Digital Asset Links (/.well-known/assetlinks.json)
ANDROID_PACKAGE_NAME=com.example.webauthn
ANDROID_SHA256_FINGERPRINTS=XX:XX:XX:...:XX

# iOS Apple App Site Association (/.well-known/apple-app-site-association)
APPLE_APP_IDS=ABCDE12345.com.example.webauthn

# WebAuthn Related Origin Requests (/.well-known/webauthn)
RELATED_ORIGINS=https://example.com,https://example.co.uk

# Passkey Endpoints - W3C Draft (/.well-known/passkey-endpoints)
PASSKEY_ENROLL_URL=https://webauthn-demo-10ja.onrender.com/passkeys/create
PASSKEY_MANAGE_URL=https://webauthn-demo-10ja.onrender.com/passkeys