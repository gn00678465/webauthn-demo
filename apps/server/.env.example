# ==============================================
# Server 環境變數
# ==============================================

# 伺服器監聽埠號
PORT=3310

# WebAuthn Relying Party 設定
# RP_ID 必須與部署的網域完全一致（不含 protocol 與 port）
# 本機開發：localhost 或 webauthn.localhost
# Render：your-app.onrender.com
RP_ID=localhost
RP_NAME=localhost

# Express Session 加密金鑰（正式環境務必使用隨機產生的強密碼）
# 產生方式：node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=

# MongoDB 連線字串
# 本機：mongodb://USERNAME:PASSWORD@HOST:PORT/DATABASE
# Atlas：mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/DATABASE
DATABASE_URL=

# ==============================================
# .well-known 設定（皆為選填，未設定則該端點回傳 404）
# ==============================================

# Android Digital Asset Links
# ANDROID_PACKAGE_NAME=com.example.passless
# ANDROID_SHA256_FINGERPRINTS=XX:XX:XX:...:XX

# iOS Apple App Site Association（格式：TEAMID.BUNDLEID）
# APPLE_APP_IDS=ABCDE12345.com.example.passless

# WebAuthn Related Origin Requests（逗號分隔，需含 https://）
# RELATED_ORIGINS=https://example.co.uk,https://example.de

# Passkey Endpoints（W3C Draft，指向使用者可操作的頁面 URL）
# PASSKEY_ENROLL_URL=https://example.com/passkeys/create
# PASSKEY_MANAGE_URL=https://example.com/passkeys
