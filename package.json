{
  "name": "@passless-demo/monorepo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "bun@1.3.11",
  "workspaces": ["apps/*", "packages/*"],
  "trustedDependencies": ["prisma", "@prisma/client", "esbuild"],
  "scripts": {
    "dev:client": "bun --filter @passless-demo/client dev",
    "dev:server": "bun --filter @passless-demo/server dev",
    "build:client": "bun --filter @passless-demo/client build",
    "build:server": "bun --filter @passless-demo/server build",
    "prisma:generate": "bun --filter @passless-demo/server prisma:generate",
    "prisma:push": "bun --filter @passless-demo/server prisma:push",
    "format": "prettier --write src/",
    "dev": "run-p dev:client dev:server",
    "build": "run-p build:client build:server"
  },
  "devDependencies": {
    "npm-run-all2": "^6.1.2",
    "prettier": "^3.1.0",
    "unocss": "^0.58.5"
  },
  "dependencies": {
    "@unocss/reset": "^0.58.5"
  }
}